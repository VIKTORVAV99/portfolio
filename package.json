    "format": "bun --filter '*' format",
    "format:check": "bun --filter '*' format:check"
  },
  "dependencies": {
    "hono": "^4.12.8"
  },
  "devDependencies": {
    "oxfmt": "^0.42.0",
    "oxlint": "^1.55.0",
    "typescript": "^6.0.2",
    "wrangler": "^4.73.0"
  },
  "engines": {
    "bun": "^1.0.0"
  }
}
