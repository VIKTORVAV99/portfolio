{
  "name": "portfolio",
  "private": true,
  "type": "module",
  "workspaces": ["apps/*"],
  "scripts": {
    "dev": "bun --filter '*' dev",
    "dev:frontend": "bun --filter frontend dev",
    "dev:backend": "bun --filter backend dev",
    "build": "bun --filter frontend build",
    "build:ci": "bun --filter frontend build:ci",
    "check:ci": "bun --filter frontend check:ci",
    "test:unit": "bun --filter '*' test:unit",
    "lint": "bun --filter '*' lint",
    "format": "bun --filter '*' format",
    "format:check": "bun --filter '*' format:check"
  },
  "engines": {
    "bun": "^1.0.0"
  }
}
